  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 📊 Financial KPI Automation\n",
    "**Author:** Nicole Espinoza — Brand Finance Intern @ Belcorp | PUCP (Top 3%)\n",
    "\n",
    "This notebook automates the calculation of key financial KPIs from raw data and generates a formatted Excel report ready to present to stakeholders."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. 📦 Import Libraries"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "from openpyxl import Workbook\n",
    "from openpyxl.styles import (\n",
    "    Font, PatternFill, Alignment, Border, Side, numbers\n",
    ")\n",
    "from openpyxl.utils.dataframe import dataframe_to_rows\n",
    "from openpyxl.chart import BarChart, Reference\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print('✅ Libraries loaded successfully')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. 📥 Load & Validate Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---------------------------------------------------------------\n",
    "# Load sample financial data\n",
    "# Replace 'data/sample_financial_data.csv' with your own file\n",
    "# ---------------------------------------------------------------\n",
    "\n",
    "data = {\n",
    "    'period': ['2024-Q1', '2024-Q2', '2024-Q3', '2024-Q4'],\n",
    "    'revenue':             [500000, 550000, 610000, 680000],\n",
    "    'cogs':                [300000, 320000, 350000, 380000],\n",
    "    'operating_expenses':  [ 80000,  85000,  90000,  95000],\n",
    "    'ebitda':              [120000, 145000, 170000, 205000],\n",
    "    'net_profit':          [ 90000, 110000, 130000, 160000],\n",
    "    'investment':          [200000, 200000, 200000, 200000]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# --- Validation ---\n",
    "required_cols = ['period','revenue','cogs','operating_expenses',\n",
    "                 'ebitda','net_profit','investment']\n",
    "missing = [c for c in required_cols if c not in df.columns]\n",
    "if missing:\n",
    "    raise ValueError(f'Missing columns: {missing}')\n",
    "\n",
    "print('✅ Data loaded and validated')\n",
    "print(f'   Periods found: {df.period.tolist()}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. 🧮 Calculate Financial KPIs"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "kpi = df.copy()\n",
    "\n",
    "# --- Core KPIs ---\n",
    "kpi['gross_margin_%']         = ((kpi['revenue'] - kpi['cogs']) / kpi['revenue'] * 100).round(2)\n",
    "kpi['ebitda_margin_%']        = (kpi['ebitda'] / kpi['revenue'] * 100).round(2)\n",
    "kpi['net_profit_margin_%']    = (kpi['net_profit'] / kpi['revenue'] * 100).round(2)\n",
    "kpi['roi_%']                  = (kpi['net_profit'] / kpi['investment'] * 100).round(2)\n",
    "kpi['opex_ratio_%']           = (kpi['operating_expenses'] / kpi['revenue'] * 100).round(2)\n",
    "\n",
    "# --- Revenue Growth YoY (quarter-over-quarter here) ---\n",
    "kpi['revenue_growth_%'] = (kpi['revenue'].pct_change() * 100).round(2)\n",
    "kpi['revenue_growth_%'].fillna(0, inplace=True)\n",
    "\n",
    "# --- Select final KPI columns ---\n",
    "kpi_display = kpi[[\n",
    "    'period',\n",
    "    'revenue',\n",
    "    'gross_margin_%',\n",
    "    'ebitda_margin_%',\n",
    "    'net_profit_margin_%',\n",
    "    'roi_%',\n",
    "    'opex_ratio_%',\n",
    "    'revenue_growth_%'\n",
    "]]\n",
    "\n",
    "print('✅ KPIs calculated')\n",
    "kpi_display"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. 📈 Visualize KPI Trends"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 2, figsize=(14, 9))\n",
    "fig.suptitle('Financial KPI Dashboard', fontsize=16, fontweight='bold', y=1.01)\n",
    "\n",
    "periods = kpi_display['period']\n",
    "colors  = ['#2563EB', '#16A34A', '#DC2626', '#D97706']\n",
    "\n",
    "# Revenue\n",
    "axes[0,0].bar(periods, kpi_display['revenue'] / 1000, color=colors[0], alpha=0.85)\n",
    "axes[0,0].set_title('Revenue (USD thousands)')\n",
    "axes[0,0].set_ylabel('USD K')\n",
    "axes[0,0].yaxis.set_major_formatter(mticker.FormatStrFormatter('%.0fK'))\n",
    "\n",
    "# Margins\n",
    "axes[0,1].plot(periods, kpi_display['gross_margin_%'],      marker='o', label='Gross Margin', color=colors[0])\n",
    "axes[0,1].plot(periods, kpi_display['ebitda_margin_%'],     marker='s', label='EBITDA Margin', color=colors[1])\n",
    "axes[0,1].plot(periods, kpi_display['net_profit_margin_%'], marker='^', label='Net Profit Margin', color=colors[2])\n",
    "axes[0,1].set_title('Margin Trends (%)')\n",
    "axes[0,1].set_ylabel('%')\n",
    "axes[0,1].legend(fontsize=8)\n",
    "\n",
    "# ROI\n",
    "axes[1,0].bar(periods, kpi_display['roi_%'], color=colors[1], alpha=0.85)\n",
    "axes[1,0].set_title('ROI (%)')\n",
    "axes[1,0].set_ylabel('%')\n",
    "\n",
    "# Revenue Growth\n",
    "bar_colors = [colors[1] if x >= 0 else colors[2] for x in kpi_display['revenue_growth_%']]\n",
    "axes[1,1].bar(periods, kpi_display['revenue_growth_%'], color=bar_colors, alpha=0.85)\n",
    "axes[1,1].axhline(0, color='black', linewidth=0.8)\n",
    "axes[1,1].set_title('Revenue Growth QoQ (%)')\n",
    "axes[1,1].set_ylabel('%')\n",
    "\n",
    "for ax in axes.flat:\n",
    "    ax.tick_params(axis='x', rotation=30)\n",
    "    ax.spines['top'].set_visible(False)\n",
    "    ax.spines['right'].set_visible(False)\n",
    "\n",
import os
os.makedirs('outputs', exist_ok=True)
    "plt.tight_layout()\n",
    "plt.savefig('outputs/kpi_charts.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('✅ Charts saved to outputs/kpi_charts.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. 📤 Export Formatted Excel Report"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "os.makedirs('outputs', exist_ok=True)\n",
    "\n",
    "wb = Workbook()\n",
    "\n",
    "# ── Helper styles ──────────────────────────────────────────────\n",
    "BLUE        = PatternFill('solid', fgColor='2563EB')\n",
    "LIGHT_BLUE  = PatternFill('solid', fgColor='DBEAFE')\n",
    "GREEN_FILL  = PatternFill('solid', fgColor='DCFCE7')\n",
    "RED_FILL    = PatternFill('solid', fgColor='FEE2E2')\n",
    "YELLOW_FILL = PatternFill('solid', fgColor='FEF9C3')\n",
    "\n",
    "WHITE_BOLD  = Font(bold=True, color='FFFFFF', size=11)\n",
    "DARK_BOLD   = Font(bold=True, color='1E3A5F', size=11)\n",
    "CENTER      = Alignment(horizontal='center', vertical='center')\n",
    "thin_border = Border(\n",
    "    left=Side(style='thin'), right=Side(style='thin'),\n",
    "    top=Side(style='thin'),  bottom=Side(style='thin')\n",
    ")\n",
    "\n",
    "# ── Sheet 1: KPI Summary ───────────────────────────────────────\n",
    "ws1 = wb.active\n",
    "ws1.title = 'KPI Summary'\n",
    "\n",
    "# Title\n",
    "ws1.merge_cells('A1:H1')\n",
    "ws1['A1'] = '📊 Financial KPI Report'\n",
    "ws1['A1'].font      = Font(bold=True, size=14, color='FFFFFF')\n",
    "ws1['A1'].fill      = BLUE\n",
    "ws1['A1'].alignment = CENTER\n",
    "ws1.row_dimensions[1].height = 30\n",
    "\n",
    "# Headers\n",
    "headers = ['Period', 'Revenue (USD)', 'Gross Margin %',\n",
    "           'EBITDA Margin %', 'Net Profit Margin %',\n",
    "           'ROI %', 'OpEx Ratio %', 'Revenue Growth %']\n",
    "for col_idx, h in enumerate(headers, start=1):\n",
    "    cell = ws1.cell(row=2, column=col_idx, value=h)\n",
    "    cell.font      = WHITE_BOLD\n",
    "    cell.fill      = PatternFill('solid', fgColor='1E3A5F')\n",
    "    cell.alignment = CENTER\n",
    "    cell.border    = thin_border\n",
    "ws1.row_dimensions[2].height = 20\n",
    "\n",
    "# Data rows with conditional formatting\n",
    "for r_idx, row in enumerate(kpi_display.itertuples(index=False), start=3):\n",
    "    row_fill = LIGHT_BLUE if r_idx % 2 == 0 else PatternFill('solid', fgColor='FFFFFF')\n",
    "    values = list(row)\n",
    "    for c_idx, val in enumerate(values, start=1):\n",
    "        cell = ws1.cell(row=r_idx, column=c_idx, value=val)\n",
    "        cell.alignment = CENTER\n",
    "        cell.border    = thin_border\n",
    "        cell.fill      = row_fill\n",
    "        # Color-code percentage columns\n",
    "        if isinstance(val, float):\n",
    "            cell.number_format = '0.00\"%\"'\n",
    "            if val >= 30:\n",
    "                cell.fill = GREEN_FILL\n",
    "            elif val < 10:\n",
    "                cell.fill = RED_FILL\n",
    "            else:\n",
    "                cell.fill = YELLOW_FILL\n",
    "        elif isinstance(val, int):\n",
    "            cell.number_format = '#,##0'\n",
    "\n",
    "# Column widths\n",
    "col_widths = [12, 16, 16, 16, 20, 10, 14, 18]\n",
    "for i, w in enumerate(col_widths, start=1):\n",
    "    ws1.column_dimensions[ws1.cell(row=1, column=i).column_letter].width = w\n",
    "\n",
    "# ── Sheet 2: Executive Summary ─────────────────────────────────\n",
    "ws2 = wb.create_sheet('Executive Summary')\n",
    "\n",
    "ws2.merge_cells('A1:D1')\n",
    "ws2['A1'] = 'Executive Summary'\n",
    "ws2['A1'].font      = Font(bold=True, size=14, color='FFFFFF')\n",
    "ws2['A1'].fill      = BLUE\n",
    "ws2['A1'].alignment = CENTER\n",
    "ws2.row_dimensions[1].height = 30\n",
    "\n",
    "latest        = kpi_display.iloc[-1]\n",
    "summary_items = [\n",
    "    ('📅 Latest Period',       latest['period']),\n",
    "    ('💰 Revenue',             f\"USD {latest['revenue']:,.0f}\"),\n",
    "    ('📈 Gross Margin',        f\"{latest['gross_margin_%']}%\"),\n",
    "    ('📊 EBITDA Margin',       f\"{latest['ebitda_margin_%']}%\"),\n",
    "    ('💵 Net Profit Margin',   f\"{latest['net_profit_margin_%']}%\"),\n",
    "    ('🔄 ROI',                 f\"{latest['roi_%']}%\"),\n",
    "    ('📉 OpEx Ratio',          f\"{latest['opex_ratio_%']}%\"),\n",
    "    ('🚀 Revenue Growth (QoQ)',f\"{latest['revenue_growth_%']}%\"),\n",
    "]\n",
    "\n",
    "for i, (label, value) in enumerate(summary_items, start=2):\n",
    "    ws2.cell(row=i, column=1, value=label).font  = DARK_BOLD\n",
    "    ws2.cell(row=i, column=1).fill               = LIGHT_BLUE\n",
    "    ws2.cell(row=i, column=1).alignment          = CENTER\n",
    "    ws2.cell(row=i, column=1).border             = thin_border\n",
    "    ws2.cell(row=i, column=2, value=value).alignment = CENTER\n",
    "    ws2.cell(row=i, column=2).border             = thin_border\n",
    "    ws2.row_dimensions[i].height                 = 22\n",
    "\n",
    "ws2.column_dimensions['A'].width = 28\n",
    "ws2.column_dimensions['B'].width = 20\n",
    "\n",
    "# ── Save ───────────────────────────────────────────────────────\n",
    "output_path = 'outputs/kpi_report.xlsx'\n",
    "wb.save(output_path)\n",
    "print(f'✅ Excel report saved → {output_path}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## ✅ Done!\n",
    "Your report is ready in `/outputs/kpi_report.xlsx`.\n",
    "\n",
    "**Next steps:**\n",
    "- Replace `data/sample_financial_data.csv` with your real data\n",
    "- Adjust KPI thresholds in the conditional formatting section\n",
    "- Adapt brand-specific metrics as needed (Brand Equity, Royalty Rate, etc.)"
   ]
